(load "Test.carp")
(load "../socket.carp")
(use Test)

(relative-include "poll_test_helpers.h")

(defmodule PollTest (register make-invalid (Fn [] Poll) "Poll_make_invalid_"))

(defn poll-accept-test []
  (match (TcpListener.bind "127.0.0.1" 0)
    (Result.Error _) false
    (Result.Success listener)
      (match (Poll.create)
        (Result.Error _) (do (TcpListener.close listener) false)
        (Result.Success poll)
          (let-do [port (TcpListener.local-port &listener)]
            (ignore (Poll.add-read &poll &listener))
            (match (TcpStream.connect "127.0.0.1" port)
              (Result.Error _)
                (do (Poll.close poll) (TcpListener.close listener) false)
              (Result.Success client)
                (match (the (Result (Array PollEvent) String)
                            (Poll.wait &poll 1000))
                  (Result.Success events)
                    (let-do [ok (and (> (Array.length &events) 0)
                                     (PollEvent.readable (Array.unsafe-nth &events
                                                                           0)))]
                      (TcpStream.close client)
                      (Poll.close poll)
                      (TcpListener.close listener)
                      ok)
                  _
                    (do
                      (TcpStream.close client)
                      (Poll.close poll)
                      (TcpListener.close listener)
                      false)))))))

(defn poll-read-test []
  (match (TcpListener.bind "127.0.0.1" 0)
    (Result.Error _) false
    (Result.Success listener)
      (let [port (TcpListener.local-port &listener)]
        (match (TcpStream.connect "127.0.0.1" port)
          (Result.Error _) (do (TcpListener.close listener) false)
          (Result.Success client)
            (match (TcpListener.accept &listener)
              (Result.Error _)
                (do (TcpStream.close client) (TcpListener.close listener) false)
              (Result.Success conn)
                (match (Poll.create)
                  (Result.Error _)
                    (do
                      (TcpStream.close conn)
                      (TcpStream.close client)
                      (TcpListener.close listener)
                      false)
                  (Result.Success poll)
                    (do
                      (ignore (Poll.add-read &poll &conn))
                      (ignore (TcpStream.send &client "hello"))
                      (match (the (Result (Array PollEvent) String)
                                  (Poll.wait &poll 1000))
                        (Result.Success events)
                          (let-do [ok (and (> (Array.length &events) 0)
                                           (PollEvent.readable (Array.unsafe-nth &events
                                                                                 0)))]
                            (Poll.close poll)
                            (TcpStream.close conn)
                            (TcpStream.close client)
                            (TcpListener.close listener)
                            ok)
                        _
                          (do
                            (Poll.close poll)
                            (TcpStream.close conn)
                            (TcpStream.close client)
                            (TcpListener.close listener)
                            false)))))))))

(defn poll-error-test []
  (let [bad (PollTest.make-invalid)]
    (match (the (Result (Array PollEvent) String) (Poll.wait &bad 0))
      (Result.Error _) (do (Poll.close bad) true)
      (Result.Success _) (do (Poll.close bad) false))))

(defn poll-timeout-test []
  (match (TcpListener.bind "127.0.0.1" 0)
    (Result.Error _) false
    (Result.Success listener)
      (match (Poll.create)
        (Result.Error _) (do (TcpListener.close listener) false)
        (Result.Success poll)
          (do
            (ignore (Poll.add-read &poll &listener))
            (match (the (Result (Array PollEvent) String) (Poll.wait &poll 50))
              (Result.Success events)
                (let-do [ok (= (Array.length &events) 0)]
                  (Poll.close poll)
                  (TcpListener.close listener)
                  ok)
              _ (do (Poll.close poll) (TcpListener.close listener) false))))))

; Regression: switching a socket from write to read interest must actually
; drop write interest. kevent() stops processing its changelist at the first
; failing entry, so deleting an unarmed filter used to skip the delete after
; it and leak EVFILT_WRITE, leaving the socket writable forever.
(defn poll-modify-drops-write-test []
  (match (TcpListener.bind "127.0.0.1" 0)
    (Result.Error _) false
    (Result.Success listener)
      (match (Poll.create)
        (Result.Error _) (do (TcpListener.close listener) false)
        (Result.Success poll)
          (let-do [port (TcpListener.local-port &listener)
                   ok false]
            (match (TcpStream.connect "127.0.0.1" port)
              (Result.Error _) ()
              (Result.Success client)
                (let-do [fd (TcpStream.poll-fd &client)]
                  ; arm write only, as an event loop does when flushing
                  (ignore (Poll.add &poll fd poll-write))
                  (ignore (Poll.wait &poll 100))
                  ; switch to read interest: write interest must be gone
                  (ignore (Poll.modify &poll fd poll-read))
                  (match (the (Result (Array PollEvent) String)
                              (Poll.wait &poll 100))
                    (Result.Success events)
                      (let-do [writable false]
                        (for [i 0 (Array.length &events)]
                          (when (PollEvent.writable (Array.unsafe-nth &events i))
                            (set! writable true)))
                        (set! ok (not writable)))
                    _ ())
                  (TcpStream.close client)))
            (Poll.close poll)
            (TcpListener.close listener)
            ok))))

(deftest test
  (assert-true test
    (match (Poll.create) (Result.Success p) (do (Poll.close p) true) _ false)
    "Poll.create succeeds")

  (assert-true test
    (poll-accept-test)
    "Poll detects listener readability on incoming connection")

  (assert-true test
    (poll-read-test)
    "Poll detects stream readability when data arrives")

  (assert-true test (poll-timeout-test) "Poll.wait returns empty on timeout")

  (assert-true test
    (poll-error-test)
    "Poll.wait returns Result.Error on invalid poll fd")

  (assert-true test
    (poll-modify-drops-write-test)
    "Poll.modify to read interest drops write interest"))
